<mvc:View
    controllerName="globalproject.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

<Page>

 
    <customHeader>
        <Bar>
    
            <contentLeft>
                <HBox alignItems="Center" class="sapUiSmallMarginBegin">

                    <Image
                        src="images/SchoolLogo.jpg"
                        width="30px"
                        height="30px"
                        class="sapUiTinyMarginEnd"/>

                    <Title text="Sudhaha School"/>

                </HBox>
            </contentLeft>

            <contentRight>
                <Button
                    text="Teacher Login"
                    type="Emphasized"
                    press="onTeacherLogin"/>

                <Button
                    text="Student Login"
                    type="Accept"
                    press="onStudentLogin"/>
            </contentRight>

        </Bar>
    </customHeader>

    <content>

        <VBox >

           
            <Carousel
                id="carousel"
                width="100%"
                height="1000px"
                showPageIndicator="true"
                loop="true">

                <Image
                    src="images/image3.jpg"
                    width="100%"
                    height="100%"/>
                
                <Image
                    src="images/image2.jpg"
                    width="100%"
                    height="100%"/>

            </Carousel>

        </VBox>

    </content>

</Page>
</mvc:View>